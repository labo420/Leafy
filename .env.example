# =============================================================================
# Leafy — Environment Variables Template
# =============================================================================
# Copia questo file come .env e compila i valori necessari.
# Su Replit, usa Tools → Secrets invece di .env
# =============================================================================

# --- OBBLIGATORIE ---

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/leafy

# Segreto per firma cookie di sessione (genera con: openssl rand -base64 32)
SESSION_SECRET=cambiami-in-produzione

# --- OPZIONALI (consigliate) ---

# Token ngrok per tunnel Expo (dev mobile)
# Registrati su https://ngrok.com → Dashboard → Your Authtoken
NGROK_AUTH_TOKEN=

# Google Vision API per OCR scontrini (senza: usa keyword matching)
GOOGLE_CLOUD_VISION_API_KEY=

# Password pannello admin (default: leafy2026)
ADMIN_PASSWORD=leafy2026

# --- AUTH OAUTH (opzionali) ---

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- AI (Anthropic Claude) ---
# Su Replit: fornite automaticamente da AI Integrations
# Su GitHub/altri: serve account Anthropic con API key propria
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# --- BARCODE API ESTERNE (opzionali, migliorano il riconoscimento) ---

# Nutritionix (https://developer.nutritionix.com — free: 500 chiamate/giorno)
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# USDA FoodData Central (https://fdc.nal.usda.gov/api-key-signup.html — opzionale, usa DEMO_KEY se assente)
USDA_API_KEY=

# --- OBJECT STORAGE (Replit auto-iniettate) ---
# Su Replit: fornite automaticamente
# Su GitHub/altri: necessita bucket GCS con service account
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- REPLIT-SPECIFIC (auto-iniettate su Replit) ---
# Su GitHub/altri: impostare manualmente
EXPO_PUBLIC_DOMAIN=localhost:8080
EXPO_PUBLIC_REPL_ID=local-dev
